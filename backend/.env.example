DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/shorts
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/1
CELERY_TASK_ALWAYS_EAGER=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ALLOW_MOCK_LLM_FALLBACK=true
# legacy 토글. true여도 새 비전 재랭크를 켭니다.
CANDIDATE_RERANK_LLM=false
# 프레임+자막 기반 비전 재랭크 토글
VISION_CANDIDATE_RERANK=false
VISION_MAX_CANDIDATES_PER_EPISODE=4
VISION_MAX_FRAMES_PER_CANDIDATE=4
VISION_IMAGE_MAX_WIDTH=640
VISION_MODEL=gpt-4.1-mini
VISION_PROMPT_VERSION=vision_candidate_rerank_v1
VISION_SCAN_VERSION=vision_scan_v1
ANALYSIS_PIPELINE_VERSION=analysis_pipeline_v2
PROXY_TRANSCODE_VERSION=proxy_v2
PROXY_MAX_WIDTH=480
PROXY_VIDEO_FPS=6
PROXY_VIDEO_CRF=31
PROXY_AUDIO_BITRATE_KBPS=64
# FFmpeg scene 필터 민감도 (0.2~0.5 권장, 낮을수록 컷 증가)
FFMPEG_SCENE_THRESHOLD=0.32
STORAGE_ROOT=./storage
# Next.js 등 다른 포트의 브라우저 클라이언트가 API를 호출할 때 (AWS 불필요)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
